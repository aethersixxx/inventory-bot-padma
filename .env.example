# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN="..."

# Google Sheets Configuration
GOOGLE_SHEET_ID="..."
GOOGLE_SHEET_NAME=Sheet1
GOOGLE_CREDENTIALS_PATH=credentials/service-account.json

# Access Control - Pisahkan dengan koma, contoh: 12345678,87654321
# Cara dapat User ID: chat dengan @userinfobot di Telegram
ADMIN_USER_IDS="ID TELEGRAM UNTUK ADMIN"
ALLOWED_USER_IDS="ID TELEGRAM UNTUK ADMIN BISA EDIT"

# Cache Configuration (detik)
CACHE_TTL=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# Gemini AI (untuk pencarian natural language)
# Dapatkan API key gratis di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="GEMINI API KEY"
GEMINI_MODEL=gemini-2.5-flash
# Kosongkan GEMINI_API_KEY untuk disable fitur AI search
